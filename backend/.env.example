# Database Configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=smartcity_db
POSTGRES_USER=smartcity_user
POSTGRES_PASSWORD=smartcity_pass_2024

MONGODB_HOST=localhost
MONGODB_PORT=27017
MONGODB_USER=smartcity_user
MONGODB_PASSWORD=smartcity_pass_2024
MONGODB_DB=smartcity_unstructured

REDIS_HOST=localhost
REDIS_PORT=6379

# LLM Configuration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
OPENAI_API_KEY=
USE_OPENAI=false

# Security
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
AES_KEY=32-byte-key-for-aes-256-encryption!!

# Application
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Data Ingestion
INGESTION_SCHEDULE=0 */6 * * *
DATA_SOURCE_RETRY_ATTEMPTS=3
DATA_SOURCE_TIMEOUT=30

# Cleanup
LOG_RETENTION_DAYS=30
CLEANUP_SCHEDULE=0 2 * * *

# Tanzania Open Data Sources (configure if different)
TANZANIA_OPEN_DATA_BASE_URL=https://www.opendata.go.tz
TANZANIA_GOV_API_URL=https://api.tanzania.go.tz
NBS_API_URL=https://www.nbs.go.tz/api
